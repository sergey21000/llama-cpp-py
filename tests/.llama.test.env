LLAMA_ARG_HF_REPO=bartowski/Qwen_Qwen3.5-0.8B-GGUF:q4_k_m
# LLAMA_ARG_MMPROJ_AUTO=0
# LLAMA_ARG_CTX_SIZE=4096
# LLAMA_ARG_N_GPU_LAYERS=auto
# LLAMA_ARG_CACHE_TYPE_K=fp16
# LLAMA_ARG_CACHE_TYPE_V=fp16
# LLAMA_ARG_N_PARALLEL=-1
LLAMA_LOG_COLORS=on
LLAMA_ARG_NO_WEBUI=1
# - 0: generic output
# - 1: error
# - 2: warning
# - 3: info
# - 4: trace (more info)
# - 5: debug
# (default: 3)
LLAMA_ARG_LOG_VERBOSITY=3
LLAMA_ARG_REASONING=off
# LLAMA_ARG_THINK_BUDGET=0
# LLAMA_ARG_MODELS_DIR=llama_cache
# LLAMA_ARG_MODELS_MAX=2
# LLAMA_CACHE=llama_cache
# LLAMA_OFFLINE=1
# HF_TOKEN=""


LLAMACPP_SERVER_TIMEOUT_WAIT=900
# LLAMACPP_RELEASE_TAG=b9886
# LLAMACPP_RELEASE_ZIP_URL=https://github.com/ggml-org/llama.cpp/releases/download/b7806/llama-b7806-bin-win-cuda-13.1-x64.zip
# LLAMACPP_DIR="/content/llama.cpp/build/bin"
LLAMACPP_LOG_LEVEL=DEBUG
